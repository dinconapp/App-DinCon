APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000

# Optional. If set, DATABASE_URL has priority over DB_*.
DATABASE_URL=

DB_HOST=
DB_PORT=5432
DB_NAME=planejamento_financeiro
DB_USER=
DB_PASSWORD=

API_PUBLIC_URL=https://api.dincon.com.br
APP_PUBLIC_URL=https://dincon.com.br
CORS_ORIGINS=https://dincon.com.br,https://www.dincon.com.br

JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
PASSWORD_ENCRYPTION_REQUIRED=true
PASSWORD_ENCRYPTION_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
TWILIO_WEBHOOK_VALIDATE_SIGNATURE=true

TWILIO_VERIFY_SERVICE_SID=
TWILIO_VERIFY_CHANNEL=sms
TWILIO_VERIFY_SMS_CHANNEL=sms

AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=whisper-1

WHATSAPP_AUDIO_STORAGE_DIR=/tmp/dincon/whatsapp/audio
WHATSAPP_KEEP_AUDIO_FILES=false
WHATSAPP_MAX_AUDIO_MB=15

PAYMENTS_PROVIDER=mercadopago
PAYMENTS_MOCK_MODE=false
PAYMENTS_DEFAULT_STATEMENT_DESCRIPTOR=DINCON
MERCADO_PAGO_API_BASE_URL=https://api.mercadopago.com
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_WEBHOOK_SECRET=
